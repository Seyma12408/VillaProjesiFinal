
@model List<ResultDealDto>
@{

	ViewData["Title"] = "Tekliflerimiz";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<table class="table table-hover table-bordered">
	@{
		int count = 0;
	}
	<tr>
		<th>#</th>
		<th>İlan Türü</th>
		<th>Resim Url</th>
		<th>Başlık</th>
		<th>Açıklama</th>
		<th>m2</th>
		<th>Kat</th>
		<th>Park Alanı</th>
		<th>Ödeme</th>


	</tr>
	@foreach (var item in Model)
	{
		count++;
		<tr>
			<th>@count</th>
			<th>@item.Type</th>
			<th>@item.ImageUrl</th>
			<th>@item.Title</th>
			<th>@(item.Description.Length>50 ? item.Description.Substring(0,50)+"...":item.Description)</th>
			<th>@item.Square</th>
			<th>@item.Floor</th>
			<th>@(item.HasParkingArea ? "Var" : "Yok")</th>
			<th>@item.PaymentType</th>

			<td>
				<button onclick="deleteDeal(this)" id="@item.Id" class="btn btn-outline-danger">Sil </button>
				<a asp-controller="Deal" asp-action="UpdateDeal" asp-route-id="@item.Id" class="btn btn-outline-info">Güncelle </a>
			</td>
		</tr>
	}
</table>
<a asp-controller="Deal" asp-action="CreateDeal" class="btn btn-outline-dark">Yeni Teklif Ekle </a>
<script>

	function deleteDeal(button){
		var id=button.getAttribute("id");
Swal.fire({
  title: "Silmek istediğinize emin misiniz?",
  text: "Bu işlemi geri alamazsınız!",
  icon: "warning",
  showCancelButton: true,
  confirmButtonColor: "#3085d6",
  cancelButtonColor: "#d33",
  confirmButtonText: "Evet, sil!",
  cancelButtonText:"İptal"
}).then((result) => {
  if (result.isConfirmed) {
   window.location.href="~/Deal/DeleteDeal/"+id;
  }
});
	}
</script>