@model CreateFeatureDto
@{
    ViewData["Title"] = "Yeni Öne Çıkan Bilgisi Ekleme Sayfası";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<form method="post">
    <label>Resim Url</label>
    <input type="text" asp-for="ImageUrl" class="form-control" />
    <span asp-validation-for="ImageUrl"></span>
    <br />
    <label>Başlık</label>
    <input type="text" asp-for="Title" class="form-control" />
    <span asp-validation-for="Title"></span>
    <br />
    <label>Alt Başlık</label>
    <input type="text" asp-for="SubTitle" class="form-control" />
    <span asp-validation-for="SubTitle"></span>
    <br />
    <label>Metrekare</label>
    <input type="text" asp-for="Square" class="form-control" />
    <span asp-validation-for="Square"></span>
    <br />
    <label>Kontrat Türü</label>
    <input type="text" asp-for="Contract" class="form-control" />
    <span asp-validation-for="Contract"></span>
    <br />
    <label>Ödeme Türü</label>
    <input type="text" asp-for="Payment" class="form-control" />
    <span asp-validation-for="Payment"></span>
    <br />
    <label>Güvenlik Durumu</label>
    <input type="text" asp-for="Safety" class="form-control" />
    <span asp-validation-for="Safety"></span>
    <br />
    <button class="btn btn-outline-dark">Kaydet</button>
</form>

@section Scripts {
    <script src="/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}