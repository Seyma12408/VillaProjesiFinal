@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
@await Component.InvokeAsync("_AdminHead")
<style>
    .input-validation-error {
        border: 2px solid #dc3545 !important;
        background-color: #fff8f8 !important;
    }

    .field-validation-error {
        color: #dc3545;
        font-size: 0.85rem;
        font-weight: 600;
        margin-top: 5px;
        display: block;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-5px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
<body>
    @await Component.InvokeAsync("_AdminPreloader")
    <div id="main-wrapper">
        @await Component.InvokeAsync("_AdminLogo")
        @await Component.InvokeAsync("_AdminNavbar")
        @await Component.InvokeAsync("_AdminSidebar")
        <div class="content-body">
            <div class="container-fluid">
                <div class="row page-titles mx-0">
                    <div class="col-sm-6 p-md-0">
                        <div class="welcome-text">
                            <h4>@ViewData["Title"]</h4>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-lg-12">
                        <div class="card">
                            <div class="card-body">
                                @RenderBody()
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        @await Component.InvokeAsync("_AdminFooter")
    </div>
    @await Component.InvokeAsync("_AdminScripts")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>