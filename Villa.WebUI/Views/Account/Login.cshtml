@model LoginDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kullanıcı Girişi</title>

    <link rel="stylesheet" href="/colorlib-regform-7/fonts/material-icon/css/material-design-iconic-font.min.css">
    <link rel="stylesheet" href="/colorlib-regform-7/css/style.css">

    <style>
        /* Hata mesajı stili */
        .error-message {
            color: #d9534f;
            font-size: 14px;
            font-weight: bold;
            margin-bottom: 15px;
            text-align: center;
            display: block;
        }

        .field-validation-error {
            color: #d9534f;
            font-size: 12px;
            margin-top: 5px;
            display: block;
        }
    </style>
</head>
<body>
    <div class="main">
        <section class="sign-in">
            <div class="container">
                <div class="signin-content">
                    <div class="signin-image">
                        <figure><img src="/colorlib-regform-7/images/signin-image.jpg" alt="login image"></figure>
                        <a href="/Account/Register" class="signup-image-link">Üye değil misiniz? Kayıt Ol</a>
                    </div>

                    <div class="signin-form">
                        <h2 class="form-title">Kullanıcı Girişi</h2>
                        <form method="POST" class="register-form" id="login-form" asp-controller="Account" asp-action="Login">

                            @* 1. GENEL HATA MESAJI (Kullanıcı adı veya şifre yanlışsa burada çıkar) *@
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="error-message">
                                    @Html.ValidationSummary(true, "")
                                </div>
                            }

                            <div class="form-group">
                                <label for="your_name"><i class="zmdi zmdi-account material-icons-name"></i></label>
                                <input type="text" asp-for="UserName" id="your_name" placeholder="Kullanıcı Adınız" />
                                <span asp-validation-for="UserName"></span>
                            </div>

                            <div class="form-group">
                                <label for="your_pass"><i class="zmdi zmdi-lock"></i></label>
                                <input type="password" asp-for="Password" id="your_pass" placeholder="Şifreniz" />
                                <span asp-validation-for="Password"></span>
                            </div>

                            <div class="form-group">
                                <input type="checkbox" name="remember-me" id="remember-me" class="agree-term" />
                                <label for="remember-me" class="label-agree-term"><span><span></span></span>Beni Hatırla</label>
                            </div>

                            <div class="form-group form-button">
                                <input type="submit" name="signin" id="signin" class="form-submit" value="Giriş Yap" />
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <script src="/colorlib-regform-7/vendor/jquery/jquery.min.js"></script>
    <script src="/colorlib-regform-7/js/main.js"></script>
</body>
</html>